{
  "name": "Duolingo Clone Dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "forwardPorts": [3000, 8000],
  "portsAttributes": {
    "3000": { "label": "Frontend (Next.js)", "onAutoForward": "openPreview" },
    "8000": { "label": "Backend (FastAPI)", "onAutoForward": "notify" }
  },
  "postCreateCommand": "pip install --break-system-packages -r backend/requirements.txt && cd frontend && npm install && cd .. && cp -n frontend/.env.local.example frontend/.env.local || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
